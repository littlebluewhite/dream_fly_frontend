VITE_API_BASE_URL=http://localhost:3000/api/v1

# Google OAuth client ID for the member 登入 page's「使用 Google 登入」button
# (authorization-code redirect to accounts.google.com; exchanged server-side
# via POST /auth/google — see docs/api/integration-contract.md §3.1). Leave
# unset/empty to hide the button entirely — the member login page works
# password-only without it (progressive enhancement).
VITE_GOOGLE_CLIENT_ID=
